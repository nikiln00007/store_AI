# Port for server
PORT=5000

# MongoDB URI (If not reachable or empty, system auto-switches to local embedded memory store!)
MONGODB_URI=mongodb://localhost:27017/dukaan_ai

# JWT Secret
JWT_SECRET=dukaan_ai_super_secret_key_2026

# OpenAI API Key (Optional: if empty or dummy, local AI Multi-Agent Simulation engine executes automatically)
OPENAI_API_KEY=your_openai_api_key_here

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
